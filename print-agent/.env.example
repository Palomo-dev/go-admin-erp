# URL y clave anónima del proyecto Supabase (mismos valores que usa la app web)
SUPABASE_URL=https://jgmgphmzusbluqhuqihj.supabase.co
SUPABASE_ANON_KEY=

# Credenciales de un usuario válido de la organización (rol con permiso de
# lectura/escritura sobre printers/print_jobs/print_agents). Se recomienda
# crear un usuario dedicado tipo "robot-impresion@tuorganizacion.com".
AGENT_EMAIL=
AGENT_PASSWORD=

# ── OPCIONAL ──
# Organización y sucursal se detectan automáticamente al arrancar:
#   1. Si el usuario pertenece a 1 sola org con 1 sola sucursal → automático
#   2. Si hay varias → menú interactivo en consola (guarda en agent-config.json)
# Solo define estas variables si quieres forzar para deployment automatizado:
# ORGANIZATION_ID=
# BRANCH_ID=

# Nombre identificador de este agente (aparece en Configuración > Impresoras / heartbeat)
AGENT_NAME=Agente Local - Sucursal Principal

# Intervalos de polling/heartbeat (ms)
POLL_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=20000

# Puerto del servidor de descubrimiento (detección de impresoras desde la web)
# La app web hace fetch a http://localhost:PUERTO/printers y /discover
DISCOVERY_PORT=3456

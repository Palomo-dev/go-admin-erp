# URL y clave anónima del proyecto Supabase (mismos valores que usa la app web)
SUPABASE_URL=https://jgmgphmzusbluqhuqihj.supabase.co
SUPABASE_ANON_KEY=

# Credenciales de un usuario válido de la organización (rol con permiso de
# lectura/escritura sobre printers/print_jobs/print_agents). Se recomienda
# crear un usuario dedicado tipo "robot-impresion@tuorganizacion.com".
AGENT_EMAIL=
AGENT_PASSWORD=

# Contexto de la organización/sucursal donde corre este agente físicamente
ORGANIZATION_ID=
BRANCH_ID=

# Nombre identificador de este agente (aparece en Configuración > Impresoras / heartbeat)
AGENT_NAME=Agente Local - Sucursal Principal

# Intervalos de polling/heartbeat (ms)
POLL_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=20000

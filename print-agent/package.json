{
  "name": "go-admin-print-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Agente local de impresión física para GO Admin ERP (POS). Escucha print_jobs en Supabase (Realtime) y envía comandos ESC/POS a impresoras USB, red, Bluetooth o del sistema.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.5",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.5",
    "escpos-usb": "^3.0.0-alpha.4",
    "escpos-bluetooth": "^3.0.0-alpha.2",
    "printer": "^0.4.1"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.16.2",
    "@types/node": "^20.14.0"
  }
}
